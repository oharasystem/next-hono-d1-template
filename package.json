{
  "name": "next-hono-d1-template",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev pages:dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm -F @next-hono-d1-template/db db:generate",
    "db:migrate": "pnpm -F @next-hono-d1-template/db db:migrate:local",
    "db:migrate:remote": "pnpm -F @next-hono-d1-template/db db:migrate:remote",
    "db:seed": "pnpm -F @next-hono-d1-template/db db:seed",
    "db:seed:remote": "pnpm -F @next-hono-d1-template/db db:seed:remote",
    "api:deploy": "pnpm -F @next-hono-d1-template/api run deploy"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "wrangler": "^3.114.17"
  },
  "dependencies": {
    "tailwindcss-animate": "^1.0.7"
  }
}
